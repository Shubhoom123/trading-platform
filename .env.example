# Copy to .env (gitignored) and fill in real values. Never commit .env.
POSTGRES_USER=trading
POSTGRES_PASSWORD=change-me
POSTGRES_DB=trading

# Redis: the Go gateway's book/quote read-through cache (Phase 5).
# Host-run gateway uses localhost:6379; containerized uses redis:6379.
# Leave REDIS_ADDR empty to disable caching (gateway falls back to the engine).
REDIS_ADDR=localhost:6379
BOOK_CACHE_TTL=750ms

# Kafka / Redpanda. Host-run services (Phase 4) use the external listener on
# localhost:19092; containerized services (Phase 6) use the internal one at
# redpanda:9092 (set directly in docker-compose.yml).
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_ORDERS_TOPIC=orders
KAFKA_FILLS_TOPIC=fills

# HS256 signing secret shared by the Java API (issuer) and Go gateway (verifier).
# Must be >= 32 bytes. Generate with: openssl rand -hex 32
JWT_SECRET=generate-a-long-random-value
